# TariffPilot retrieval backend — FastAPI + retrieval pipeline + baked DB.
# Build context is the REPO ROOT (see docker-compose.yml).
#
#   docker buildx build --platform linux/amd64 \
#     -f docker/Dockerfile.backend -t <you>/tariffpilot-backend:latest --push .
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

# onnxruntime (Chroma's default embedder) needs libgomp at runtime.
RUN apt-get update && apt-get install -y --no-install-recommends libgomp1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements-serve.txt .
RUN pip install --no-cache-dir -r requirements-serve.txt

# Bake the Chroma ONNX MiniLM model into the image so the FIRST request doesn't
# download it at runtime — keeps startup < 60s and works with no egress.
RUN python -c "from chromadb.utils.embedding_functions import DefaultEmbeddingFunction; DefaultEmbeddingFunction()(['warm'])"

# App code + data stores (read-only at serve time). Ingestion dirs are NOT
# copied — the live app only reads the baked Database/.
COPY config.py ./
COPY llm ./llm
COPY retrieval ./retrieval
COPY app ./app
COPY Database ./Database

EXPOSE 8000

HEALTHCHECK --interval=10s --timeout=3s --start-period=40s --retries=5 \
  CMD python -c "import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://localhost:8000/health').status==200 else 1)"

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
