# Copy to docker/.env and fill in. NEVER commit the filled .env (gitignored).
# Compose reads this for ${...} interpolation; keys are injected at RUNTIME only,
# never baked into an image layer.

# ── LLM: primary backend ─────────────────────────────────────────────────────
# TESTING NOW (Fireworks only): keep local disabled.
LLM_LOCAL_ENABLED=0

# WHEN THE AMD DROPLET IS UP: set to 1 and point at it (vLLM OpenAI-compat).
# LLM_LOCAL_ENABLED=1
# LLM_BASE_URL=http://<droplet-public-ip>:8000/v1
# LLM_API_KEY=<the token you set on vLLM>
# LLM_MODEL=openai/gpt-oss-20b
LLM_TIMEOUT=8

# ── LLM: Fireworks fallback (also the current test backend) ───────────────────
FIREWORKS_API_KEY=fw_your_key_here
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-20b
FIREWORKS_TIMEOUT=12
